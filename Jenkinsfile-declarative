pipeline {
    agent any

    environment {
        NVM_DIR = "/var/lib/jenkins/.nvm"
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                . "$NVM_DIR/nvm.sh"
                nvm use 20
                npm install
                '''
            }
        }

        stage('Run App') {
            steps {
                sh '''
                . "$NVM_DIR/nvm.sh"
                nvm use 20

                # Stop previous app if running
                pkill -f "node app.js" || true

                # Start app in background
                nohup node app.js > app.log 2>&1 &

                # Wait for app to start
                sleep 10

                # Check app
                curl http://localhost:3001 || echo "App is not responding!"
                '''
            }
        }
    }

    post {
        always {
            echo 'Cleaning up...'
        }
    }
}